---
import Layout from "../layouts/Layout.astro";
import NeuralPhoenixLogo from "../components/NeuralPhoenixLogo.astro";
---

<Layout
  title="Welcome to Your Portal"
  description="Subscription confirmed. Welcome to AI Empowerment Group."
>
  <main id="success-page" aria-live="polite" aria-atomic="true">

    <!-- ── Loading state (default, visible on first render) ── -->
    <section id="state-loading" class="state" aria-label="Verifying your subscription">
      <NeuralPhoenixLogo size={72} />
      <div class="spinner" aria-hidden="true"></div>
      <p class="status-text">Verifying your subscription&hellip;</p>
    </section>

    <!-- ── Success state (hidden until JS confirms active status) ── -->
    <section id="state-success" class="state hidden" aria-label="Subscription confirmed">
      <div class="glow-ring" aria-hidden="true">
        <NeuralPhoenixLogo size={96} />
      </div>
      <h1 id="welcome-heading">Welcome!</h1>
      <p class="sub-headline">Your subscription is active.</p>
      <p class="body-copy">
        You now have full access to your private consulting channel.<br />
        Ask questions, share files, and get direct responses — any time.
      </p>
      <div class="divider" aria-hidden="true"></div>
      <a href="/portal" class="btn-primary" id="portal-cta">
        Enter Your Portal
        <span class="btn-arrow" aria-hidden="true">&rarr;</span>
      </a>
      <p class="billing-note">
        Your card will be charged <strong>$750 weekly</strong>. Manage or cancel anytime in your account settings.
      </p>
    </section>

    <!-- ── Pending state (webhook processing delay) ── -->
    <section id="state-pending" class="state hidden" aria-label="Setting up your account">
      <NeuralPhoenixLogo size={72} />
      <div class="spinner spinner--gold" aria-hidden="true"></div>
      <p class="status-text">Setting up your account&hellip;</p>
      <p class="status-sub">Payment received. This takes just a moment.</p>
    </section>

    <!-- ── Error state ── -->
    <section id="state-error" class="state hidden" aria-label="Verification error">
      <NeuralPhoenixLogo size={72} />
      <h2 class="error-heading">Something went wrong.</h2>
      <p id="error-message" class="error-copy">
        We could not verify your subscription. Please try refreshing, or contact us directly.
      </p>
      <div class="error-actions">
        <button class="btn-secondary" onclick="window.location.reload()">Try Again</button>
        <a href="/contact" class="btn-ghost">Contact Support</a>
      </div>
    </section>

  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 2rem;
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(201,168,76,0.08) 0%, transparent 70%),
      var(--color-charcoal);
  }

  /* ── State containers ── */
  .state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    max-width: 540px;
    width: 100%;
    animation: fadeIn 0.4s ease both;
  }

  .state.hidden {
    display: none;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Logo glow ring (success only) ── */
  .glow-ring {
    position: relative;
    padding: 1.5rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.15) 0%, transparent 70%);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(201,168,76,0.0); }
    50%       { box-shadow: 0 0 40px 8px rgba(201,168,76,0.18); }
  }

  /* ── Spinner ── */
  .spinner {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(245,245,240,0.15);
    border-top-color: var(--color-off-white);
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
  }

  .spinner--gold {
    border-top-color: var(--color-gold);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* ── Typography ── */
  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--color-gold);
    letter-spacing: -0.01em;
  }

  .sub-headline {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-off-white);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-family: var(--font-heading);
  }

  .body-copy {
    font-size: 1rem;
    color: rgba(245,245,240,0.75);
    line-height: 1.7;
    max-width: 420px;
  }

  .status-text {
    font-size: 1.0625rem;
    color: var(--color-off-white);
    font-weight: 500;
  }

  .status-sub {
    font-size: 0.875rem;
    color: var(--color-mid-grey);
  }

  /* ── Gold divider ── */
  .divider {
    width: 48px;
    height: 2px;
    background: var(--color-gold);
    border-radius: 2px;
    opacity: 0.6;
  }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
    padding: 0.875rem 2rem;
    border-radius: 4px;
    text-decoration: none;
    transition: filter 0.15s ease, transform 0.15s ease;
  }

  .btn-primary:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .btn-arrow {
    font-size: 1.125rem;
    transition: transform 0.15s ease;
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(3px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-gold);
    border: 1.5px solid var(--color-gold);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .btn-secondary:hover {
    background: rgba(201,168,76,0.1);
  }

  .btn-ghost {
    color: var(--color-mid-grey);
    font-size: 0.875rem;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .btn-ghost:hover {
    color: var(--color-off-white);
  }

  .error-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Error ── */
  .error-heading {
    font-size: 1.5rem;
    color: var(--color-error);
    font-family: var(--font-heading);
  }

  .error-copy {
    color: rgba(245,245,240,0.7);
    max-width: 380px;
  }

  /* ── Billing note ── */
  .billing-note {
    font-size: 0.8125rem;
    color: var(--color-mid-grey);
    max-width: 360px;
  }

  .billing-note strong {
    color: rgba(245,245,240,0.6);
  }
</style>

<script>
  import { initializeApp, getApps } from "firebase/app";
  import { getAuth, onAuthStateChanged } from "firebase/auth";
  import { getFunctions, httpsCallable } from "firebase/functions";

  // ── Firebase config — replace with your actual project values ──
  const firebaseConfig = {
    apiKey:            import.meta.env.PUBLIC_FIREBASE_API_KEY,
    authDomain:        import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN,
    projectId:         import.meta.env.PUBLIC_FIREBASE_PROJECT_ID,
    storageBucket:     import.meta.env.PUBLIC_FIREBASE_STORAGE_BUCKET,
    messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID,
    appId:             import.meta.env.PUBLIC_FIREBASE_APP_ID,
  };

  const app = getApps().length ? getApps()[0] : initializeApp(firebaseConfig);
  const auth = getAuth(app);
  const functions = getFunctions(app);

  // ── State helpers ──
  type PageState = "loading" | "success" | "pending" | "error";

  function showState(state: PageState) {
    const states: PageState[] = ["loading", "success", "pending", "error"];
    states.forEach((s) => {
      const el = document.getElementById(`state-${s}`);
      if (el) {
        el.classList.toggle("hidden", s !== state);
        // Re-trigger CSS animation on reveal
        if (s === state) {
          el.style.animation = "none";
          void el.offsetHeight; // reflow
          el.style.animation = "";
        }
      }
    });
  }

  function setWelcomeName(displayName: string | null) {
    const heading = document.getElementById("welcome-heading");
    if (!heading) return;
    const firstName = displayName?.split(" ")[0] || "there";
    heading.textContent = `Welcome, ${firstName}!`;
  }

  function setError(message: string) {
    const el = document.getElementById("error-message");
    if (el) el.textContent = message;
    showState("error");
  }

  // ── Subscription verification with retry ──
  const verifySubscription = httpsCallable<
    { sessionId: string | null },
    { status: string; firstName: string }
  >(functions, "verifySubscription");

  const MAX_RETRIES = 5;
  const RETRY_DELAY_MS = 3000;

  async function checkSubscription(
    sessionId: string | null,
    attempt = 1
  ): Promise<void> {
    try {
      const result = await verifySubscription({ sessionId });
      const { status, firstName } = result.data;

      if (status === "active") {
        setWelcomeName(firstName || null);
        showState("success");
        return;
      }

      // Webhook not yet processed — retry
      if (attempt < MAX_RETRIES) {
        showState("pending");
        await new Promise((r) => setTimeout(r, RETRY_DELAY_MS));
        return checkSubscription(sessionId, attempt + 1);
      }

      // Max retries hit — still not active
      setError(
        "Your payment was received but we are still activating your account. " +
        "Please refresh in a minute or contact us if this persists."
      );
    } catch (err: any) {
      const code = err?.code ?? "";
      if (code === "unauthenticated") {
        // Not logged in — redirect to login, then return here
        window.location.href = `/login?redirect=${encodeURIComponent(window.location.href)}`;
        return;
      }
      setError(
        "We could not verify your subscription. Please try refreshing, or contact us directly."
      );
    }
  }

  // ── Entry point: wait for Firebase Auth to resolve ──
  const sessionId = new URLSearchParams(window.location.search).get("session_id");

  onAuthStateChanged(auth, (user) => {
    if (!user) {
      // Not authenticated — redirect to login
      window.location.href = `/login?redirect=${encodeURIComponent(window.location.href)}`;
      return;
    }
    // Auth resolved — now verify subscription with server
    checkSubscription(sessionId);
  });
</script>
