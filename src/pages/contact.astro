---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact"
  description="Schedule a consultation with AI Empowerment Group. AI Strategy, Data Visualisation, and Cybersecurity services."
>

  <div class="page-wrap">
    <div class="page-inner">

      <!-- Left: info -->
      <aside class="contact-info">
        <span class="label-tag">Get In Touch</span>
        <h1>Let&rsquo;s Talk.</h1>
        <p class="info-body">
          Tell me where you are and where you want to get to.
          I'll tell you honestly whether I can help — and how.
        </p>

        <div class="info-divider" aria-hidden="true"></div>

        <dl class="contact-details">
          <div class="detail">
            <dt>Response time</dt>
            <dd>Within 24 hours</dd>
          </div>
          <div class="detail">
            <dt>Consultation</dt>
            <dd>First call is always free</dd>
          </div>
          <div class="detail">
            <dt>Training retainer</dt>
            <dd>$750 / week</dd>
          </div>
        </dl>
      </aside>

      <!-- Right: form -->
      <main class="contact-form-wrap">
        <form
          id="contact-form"
          class="contact-form"
          novalidate
          aria-label="Contact enquiry form"
        >

          <!-- Full Name -->
          <div class="field-group">
            <label for="name">Full Name <span class="required" aria-label="required">*</span></label>
            <input
              type="text"
              id="name"
              name="name"
              autocomplete="name"
              required
              aria-required="true"
              aria-describedby="name-error"
              placeholder="Your full name"
            />
            <span id="name-error" class="field-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- Email -->
          <div class="field-group">
            <label for="email">Email Address <span class="required" aria-label="required">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              required
              aria-required="true"
              aria-describedby="email-error"
              placeholder="you@company.com"
            />
            <span id="email-error" class="field-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- Country -->
          <div class="field-group">
            <label for="country">Country <span class="required" aria-label="required">*</span></label>
            <div class="select-wrap">
              <select
                id="country"
                name="country"
                required
                aria-required="true"
                aria-describedby="country-error"
              >
                <option value="" disabled selected>Select your country</option>
                <option>United Kingdom</option>
                <option>United States</option>
                <option>Canada</option>
                <option>Australia</option>
                <option>Ireland</option>
                <option>Germany</option>
                <option>France</option>
                <option>Netherlands</option>
                <option>South Africa</option>
                <option>Nigeria</option>
                <option>Kenya</option>
                <option>India</option>
                <option>Singapore</option>
                <option>UAE</option>
                <option>Other</option>
              </select>
              <span class="select-arrow" aria-hidden="true">&#9660;</span>
            </div>
            <span id="country-error" class="field-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- Nature of Inquiry -->
          <div class="field-group">
            <label for="inquiry">Nature of Inquiry <span class="required" aria-label="required">*</span></label>
            <div class="select-wrap">
              <select
                id="inquiry"
                name="inquiry"
                required
                aria-required="true"
                aria-describedby="inquiry-error"
              >
                <option value="" disabled selected>Select a service</option>
                <option value="ai-strategy">AI Strategy &amp; Training</option>
                <option value="data-viz">Data Visualisation (Tableau / Power BI / Fabric)</option>
                <option value="cyber">Cyber Threat Hunting</option>
                <option value="general">General Enquiry</option>
              </select>
              <span class="select-arrow" aria-hidden="true">&#9660;</span>
            </div>
            <span id="inquiry-error" class="field-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- Message -->
          <div class="field-group">
            <label for="message">Message <span class="required" aria-label="required">*</span></label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              aria-required="true"
              aria-describedby="message-error"
              placeholder="Tell me about your team, your challenge, and what you're hoping to achieve."
            ></textarea>
            <span id="message-error" class="field-error" role="alert" aria-live="polite"></span>
          </div>

          <!-- Submit -->
          <button type="submit" class="submit-btn" id="submit-btn">
            Send Message
          </button>

          <!-- Form-level feedback -->
          <div id="form-success" class="form-banner form-banner--success" role="alert" aria-live="polite" hidden>
            Thank you — we'll be in touch within 24 hours.
          </div>
          <div id="form-error" class="form-banner form-banner--error" role="alert" aria-live="polite" hidden>
            Something went wrong. Please try again or email us directly.
          </div>

        </form>
      </main>

    </div>
  </div>

</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const successBanner = document.getElementById("form-success") as HTMLElement;
  const errorBanner = document.getElementById("form-error") as HTMLElement;

  type FieldId = "name" | "email" | "country" | "inquiry" | "message";

  function setError(id: FieldId, message: string) {
    const field = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
    const errEl = document.getElementById(`${id}-error`) as HTMLElement;
    field.setAttribute("aria-invalid", "true");
    field.classList.add("invalid");
    errEl.textContent = message;
  }

  function clearError(id: FieldId) {
    const field = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
    const errEl = document.getElementById(`${id}-error`) as HTMLElement;
    field.removeAttribute("aria-invalid");
    field.classList.remove("invalid");
    errEl.textContent = "";
  }

  function validate(): boolean {
    let valid = true;
    const name = (document.getElementById("name") as HTMLInputElement).value.trim();
    const email = (document.getElementById("email") as HTMLInputElement).value.trim();
    const country = (document.getElementById("country") as HTMLSelectElement).value;
    const inquiry = (document.getElementById("inquiry") as HTMLSelectElement).value;
    const message = (document.getElementById("message") as HTMLTextAreaElement).value.trim();

    if (!name) { setError("name", "Please enter your full name."); valid = false; }
    else clearError("name");

    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!email) { setError("email", "Please enter your email address."); valid = false; }
    else if (!emailRe.test(email)) { setError("email", "Please enter a valid email address."); valid = false; }
    else clearError("email");

    if (!country) { setError("country", "Please select your country."); valid = false; }
    else clearError("country");

    if (!inquiry) { setError("inquiry", "Please select the nature of your inquiry."); valid = false; }
    else clearError("inquiry");

    if (!message || message.length < 10) { setError("message", "Please enter a message (at least 10 characters)."); valid = false; }
    else clearError("message");

    return valid;
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    successBanner.hidden = true;
    errorBanner.hidden = true;

    if (!validate()) {
      // Move focus to first invalid field
      const firstInvalid = form.querySelector("[aria-invalid='true']") as HTMLElement | null;
      firstInvalid?.focus();
      return;
    }

    submitBtn.textContent = "Sending…";
    submitBtn.disabled = true;

    // TODO: replace with Firebase Function call
    await new Promise((r) => setTimeout(r, 1200)); // Simulated delay for local testing

    // Simulated success — replace with real submit logic
    successBanner.hidden = false;
    form.reset();
    submitBtn.textContent = "Send Message";
    submitBtn.disabled = false;
    successBanner.scrollIntoView({ behavior: "smooth", block: "nearest" });
  });

  // Inline real-time validation on blur
  (["name", "email", "country", "inquiry", "message"] as FieldId[]).forEach((id) => {
    document.getElementById(id)?.addEventListener("blur", () => validate());
  });
</script>

<style>
  .page-wrap {
    padding: clamp(3.5rem, 7vw, 6rem) clamp(1.25rem, 5vw, 4rem);
    min-height: calc(100vh - 68px);
  }

  .page-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 5rem;
    align-items: start;
  }

  @media (max-width: 860px) {
    .page-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  /* ── Info panel ── */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 100px;
  }

  .label-tag {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold);
    border: 1px solid rgba(201,168,76,0.3);
    padding: 0.3rem 0.9rem;
    border-radius: 2px;
    align-self: flex-start;
  }

  .contact-info h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    color: var(--color-off-white);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .info-body {
    font-size: 1rem;
    color: rgba(245,245,240,0.65);
    line-height: 1.75;
  }

  .info-divider {
    height: 1px;
    background: rgba(201,168,76,0.2);
    margin: 0.5rem 0;
  }

  .contact-details { display: flex; flex-direction: column; gap: 1rem; }

  .detail dt {
    font-family: var(--font-heading);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.2rem;
  }

  .detail dd {
    font-size: 0.9375rem;
    color: rgba(245,245,240,0.7);
  }

  /* ── Form ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(245,245,240,0.8);
  }

  .required { color: var(--color-gold); margin-left: 2px; }

  input, select, textarea {
    background: #1e1e1e;
    border: 1.5px solid rgba(245,245,240,0.12);
    border-radius: 4px;
    color: var(--color-off-white);
    font-family: var(--font-body);
    font-size: 1rem;
    padding: 0.8rem 1rem;
    transition: border-color 0.15s ease;
    width: 100%;
  }

  input::placeholder, textarea::placeholder { color: rgba(245,245,240,0.25); }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.12);
  }

  input.invalid, select.invalid, textarea.invalid {
    border-color: var(--color-error);
    box-shadow: 0 0 0 3px rgba(204,51,51,0.12);
  }

  textarea { resize: vertical; min-height: 130px; }

  .select-wrap { position: relative; }
  .select-wrap select { appearance: none; padding-right: 2.5rem; cursor: pointer; }
  .select-arrow {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-gold);
    font-size: 0.75rem;
    pointer-events: none;
  }

  .field-error {
    font-size: 0.8125rem;
    color: var(--color-error);
    min-height: 1.1em;
  }

  .submit-btn {
    background: var(--color-gold);
    color: var(--color-charcoal);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9375rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: none;
    border-radius: 4px;
    padding: 0.9rem 2rem;
    cursor: pointer;
    align-self: flex-start;
    transition: filter 0.15s ease, transform 0.15s ease;
  }

  .submit-btn:hover:not(:disabled) { filter: brightness(1.1); transform: translateY(-1px); }
  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .form-banner {
    border-radius: 4px;
    padding: 1rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 500;
  }

  .form-banner--success { background: rgba(45,125,50,0.15); border: 1px solid rgba(45,125,50,0.4); color: #6fcf7c; }
  .form-banner--error   { background: rgba(204,51,51,0.15);  border: 1px solid rgba(204,51,51,0.4);  color: #f08080; }
</style>
