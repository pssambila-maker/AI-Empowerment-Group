---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Client Login" description="Client portal login — AI Empowerment Group." hideFooter={false}>

  <main class="login-page" aria-label="Client login">
    <div class="login-card">

      <div class="login-logo">
        <img src="/images/logo/neural-phoenix.png" alt="AI Empowerment Group" height="64" />
      </div>

      <div class="login-header">
        <h1>Client Portal</h1>
        <p>Sign in to access your private consulting channel.</p>
      </div>

      <form id="login-form" novalidate aria-label="Login form">

        <div class="field-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" autocomplete="email" required aria-required="true" placeholder="you@company.com" />
          <span id="email-error" class="field-error" role="alert"></span>
        </div>

        <div class="field-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" autocomplete="current-password" required aria-required="true" placeholder="Your password" />
          <span id="password-error" class="field-error" role="alert"></span>
        </div>

        <button type="submit" class="login-btn" id="login-btn">Sign In</button>

        <div id="login-error" class="form-error" role="alert" aria-live="polite" hidden>
          Invalid email or password. Please try again.
        </div>

      </form>

      <div class="login-divider"><span>or</span></div>

      <button class="google-btn" id="google-btn" type="button">
        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
          <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z"/>
          <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
          <path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/>
          <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/>
        </svg>
        Continue with Google
      </button>

      <p class="forgot-link">
        <a href="/contact">Not a client yet?</a> &nbsp;·&nbsp;
        <button type="button" id="forgot-btn" class="text-btn">Forgot password?</button>
      </p>

    </div>
  </main>

</Layout>

<script>
  // Firebase Auth will be wired in Phase 2.
  // This is the UI scaffold for local testing.
  const form = document.getElementById("login-form") as HTMLFormElement;
  const loginBtn = document.getElementById("login-btn") as HTMLButtonElement;
  const loginError = document.getElementById("login-error") as HTMLElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    loginError.hidden = true;
    loginBtn.textContent = "Signing in…";
    loginBtn.disabled = true;
    // TODO: replace with Firebase Auth sign-in
    await new Promise((r) => setTimeout(r, 1000));
    loginError.hidden = false;
    loginBtn.textContent = "Sign In";
    loginBtn.disabled = false;
  });

  document.getElementById("forgot-btn")?.addEventListener("click", () => {
    alert("Password reset — Firebase Auth to be wired in Phase 2.");
  });

  document.getElementById("google-btn")?.addEventListener("click", () => {
    alert("Google Sign-In — Firebase Auth to be wired in Phase 2.");
  });
</script>

<style>
  .login-page {
    min-height: calc(100vh - 68px);
    display: grid;
    place-items: center;
    padding: 2rem;
    background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(201,168,76,0.06) 0%, transparent 70%), var(--color-charcoal);
  }

  .login-card {
    width: 100%;
    max-width: 420px;
    background: #222;
    border-radius: 8px;
    border-top: 3px solid var(--color-gold);
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  .login-logo { text-align: center; }
  .login-logo img { height: 64px; width: auto; mix-blend-mode: lighten; }

  .login-header { text-align: center; }
  .login-header h1 { font-family: var(--font-heading); font-size: 1.5rem; font-weight: 800; color: var(--color-off-white); }
  .login-header p { font-size: 0.9rem; color: var(--color-mid-grey); margin-top: 0.375rem; }

  form { display: flex; flex-direction: column; gap: 1.125rem; }

  .field-group { display: flex; flex-direction: column; gap: 0.375rem; }
  label { font-family: var(--font-heading); font-size: 0.8rem; font-weight: 700; letter-spacing: 0.04em; color: rgba(245,245,240,0.7); }
  input { background: #1a1a1a; border: 1.5px solid rgba(245,245,240,0.1); border-radius: 4px; color: var(--color-off-white); font-size: 1rem; padding: 0.75rem 1rem; width: 100%; transition: border-color 0.15s; }
  input:focus { outline: none; border-color: var(--color-gold); box-shadow: 0 0 0 3px rgba(201,168,76,0.12); }
  input::placeholder { color: rgba(245,245,240,0.2); }
  .field-error { font-size: 0.8rem; color: var(--color-error); min-height: 1em; }

  .login-btn { background: var(--color-gold); color: var(--color-charcoal); font-family: var(--font-heading); font-weight: 700; font-size: 0.9375rem; letter-spacing: 0.05em; text-transform: uppercase; border: none; border-radius: 4px; padding: 0.85rem; cursor: pointer; transition: filter 0.15s, transform 0.15s; }
  .login-btn:hover:not(:disabled) { filter: brightness(1.1); transform: translateY(-1px); }
  .login-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .form-error { background: rgba(204,51,51,0.1); border: 1px solid rgba(204,51,51,0.3); border-radius: 4px; padding: 0.75rem 1rem; font-size: 0.875rem; color: #f08080; }

  .login-divider { display: flex; align-items: center; gap: 1rem; }
  .login-divider::before, .login-divider::after { content: ""; flex: 1; height: 1px; background: rgba(255,255,255,0.08); }
  .login-divider span { font-size: 0.75rem; color: var(--color-mid-grey); }

  .google-btn { display: flex; align-items: center; justify-content: center; gap: 0.75rem; background: #fff; color: #333; font-family: var(--font-body); font-size: 0.9rem; font-weight: 500; border: none; border-radius: 4px; padding: 0.75rem; cursor: pointer; transition: filter 0.15s; }
  .google-btn:hover { filter: brightness(0.95); }

  .forgot-link { text-align: center; font-size: 0.8125rem; color: var(--color-mid-grey); }
  .forgot-link a { color: rgba(201,168,76,0.7); text-decoration: underline; }
  .forgot-link a:hover { color: var(--color-gold); }
  .text-btn { background: none; border: none; color: rgba(201,168,76,0.7); font-size: 0.8125rem; cursor: pointer; text-decoration: underline; padding: 0; }
  .text-btn:hover { color: var(--color-gold); }
</style>
